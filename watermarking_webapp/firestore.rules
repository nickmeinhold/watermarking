rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile: owner only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Original images: owner can read and create, update only the delete flag
    match /originalImages/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Marked images: owner can read and create
    match /markedImages/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Detection items: owner can read
    match /detectionItems/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Detecting status: owner only
    match /detecting/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tasks: authenticated users can create (with their own userId), backend handles the rest
    match /tasks/{taskId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
